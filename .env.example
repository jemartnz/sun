# Sun API — Variables de entorno requeridas en produccion
# Copiar a .env y completar con valores reales (nunca commitear .env)

# Base de datos SQL Server
ConnectionStrings__Sun=Server=localhost,1433;Database=SunDb;User Id=sa;Password=TU_PASSWORD;TrustServerCertificate=true

# JWT
Jwt__Secret=TU_CLAVE_SECRETA_BASE64_MIN_32_CHARS
Jwt__Issuer=SunApp
Jwt__Audience=SunApp
Jwt__ExpiryMinutes=15
Jwt__RefreshTokenExpiryDays=7

# Admin seed
AdminSeed__Email=admin@tudominio.com
AdminSeed__Password=TU_PASSWORD_ADMIN

# CORS — origenes permitidos (separar multiples con indice)
Cors__AllowedOrigins__0=https://tuapp.com
Cors__AllowedOrigins__1=https://www.tuapp.com

# Seq (opcional — dejar vacio para deshabilitar)
Seq__ServerUrl=http://localhost:5341
